<!DOCTYPE html>
<html>
<head>
    <title>{{ website_title }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(to right, #1f4037, #99f2c8);
            color: white;
            text-align: center;
            padding-top: 100px;
        }
        .card {
            background: rgba(0,0,0,0.6);
            padding: 40px;
            border-radius: 12px;
            width: 60%;
            margin: auto;
            box-shadow: 0px 10px 25px rgba(0,0,0,0.4);
        }
        h1 {
            font-size: 48px;
        }
        p {
            font-size: 20px;
        }
        footer {
            margin-top: 40px;
            font-size: 14px;
            color: #ddd;
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>{{ website_title }}</h1>
        <p>{{ website_message }}</p>
        <p>Server: {{ ansible_facts['hostname'] }}</p>
        <p>IP: {{ ansible_facts['default_ipv4']['address'] }}</p>
        <footer>
            Deployed using Ansible on RHEL 10 🚀
        </footer>
    </div>
</body>
</html>
