<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ website_title }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            line-height: 1.6;
            color: #333;
        }

        header {
            background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e') no-repeat center center/cover;
            height: 100vh;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        header h1 {
            font-size: 3rem;
        }

        header p {
            margin: 20px 0;
            font-size: 1.2rem;
        }

        .btn {
            display: inline-block;
            padding: 10px 25px;
            background: #ff6b6b;
            color: white;
            text-decoration: none;
            border-radius: 25px;
            transition: 0.3s;
        }

        .btn:hover {
            background: #ff4757;
        }

        section {
            padding: 60px 10%;
            text-align: center;
        }

        .about img, .services img {
            width: 100%;
            max-width: 400px;
            border-radius: 10px;
            margin: 20px 0;
        }

        .services-container {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-around;
            gap: 20px;
        }

        .service-box {
            flex: 1 1 300px;
            background: #f4f4f4;
            padding: 20px;
            border-radius: 10px;
            transition: 0.3s;
        }

        .service-box:hover {
            transform: translateY(-10px);
        }

        form {
            max-width: 500px;
            margin: auto;
            display: flex;
            flex-direction: column;
        }

        form input, form textarea {
            margin: 10px 0;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        form button {
            padding: 10px;
            background: #1e90ff;
            color: white;
            border: none;
            border-radius: 25px;
            cursor: pointer;
        }

        form button:hover {
            background: #3742fa;
        }

        footer {
            background: #222;
            color: white;
            padding: 20px;
            text-align: center;
        }

        @media(max-width: 768px) {
            .services-container {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<header>
    <div>
        <h1>Welcome to My Website</h1>
        <p>Clean. Modern. Responsive One Page Website.</p>
        <a href="#contact" class="btn">Get Started</a>
    </div>
</header>

<section class="about">
    <h2>About Us</h2>
    <img src="https://images.unsplash.com/photo-1492724441997-5dc865305da7" alt="About Image">
    <p>
        We create modern and responsive websites with beautiful layouts 
        and smooth user experiences. Our goal is to deliver high-quality 
        digital solutions for businesses and individuals.
    </p>
</section>

<section class="services">
    <h2>Our Services</h2>
    <div class="services-container">
        <div class="service-box">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f" alt="Web Design">
            <h3>Web Design</h3>
            <p>Creative and user-friendly website designs tailored to your needs.</p>
        </div>
        <div class="service-box">
            <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c" alt="Development">
            <h3>Development</h3>
            <p>Fast and scalable web development using modern technologies.</p>
        </div>
        <div class="service-box">
            <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c" alt="Marketing">
            <h3>Digital Marketing</h3>
            <p>Grow your brand visibility with strategic digital marketing solutions.</p>
        </div>
    </div>
</section>

<section id="contact">
    <h2>Contact Us</h2>
    <form>
        <input type="text" placeholder="Your Name" required>
        <input type="email" placeholder="Your Email" required>
        <textarea rows="5" placeholder="Your Message" required></textarea>
        <button type="submit">Send Message</button>
    </form>
</section>

<footer>
    <p>&copy; 2026 My Website | All Rights Reserved</p>
    <div class="card">
        <h1>{{ website_title }}</h1>
        <p>{{ website_message }}</p>
        <p>Server: {{ ansible_facts['hostname'] }}</p>
        <p>IP: {{ ansible_facts['default_ipv4']['address'] }}</p>
        <footer>
            Deployed using Ansible on RHEL 10 🚀
        </footer>
    </div>
</footer>
</body>
</html>
